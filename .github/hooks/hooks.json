{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash .github/hooks/log-session.sh sessionStart",
        "powershell": "& '.github/hooks/log-session.ps1' -Event sessionStart",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash .github/hooks/log-session.sh sessionEnd",
        "powershell": "& '.github/hooks/log-session.ps1' -Event sessionEnd",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}